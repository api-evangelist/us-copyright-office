      "@type": "xsd:string"
    },
    "service_provider_name": {
      "@id": "usco:service_provider_name",
      "@type": "xsd:string"
    },
    "service_provider_url": {
      "@id": "usco:service_provider_url",
      "@type": "@id"
    },
    "status": {
      "@id": "usco:status",
      "@type": "xsd:string"
    },
    "termination_notice": {
      "@id": "usco:termination_notice",
      "@type": "xsd:boolean"
    },
    "title": "schema:name",
    "titles": {
      "@id": "usco:titles",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "volume": {
      "@id": "usco:volume",
      "@type": "xsd:string"
    },
    "work_category": {
      "@id": "usco:work_category",
